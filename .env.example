APP_NAME="OpenSales POS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8100

APP_LOCALE=uz
APP_FALLBACK_LOCALE=uz

LOG_CHANNEL=stack
LOG_LEVEL=error

# Offline — bitta SQLite fayl, qo'shimcha xizmat (Postgres/Redis) kerak emas.
DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# NativePHP desktop
NATIVEPHP_APP_ID=uz.opensales.pos
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_AUTHOR="OpenSales"
NATIVEPHP_UPDATER_ENABLED=false
